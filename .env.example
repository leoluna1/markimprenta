NODE_ENV=production
PORT=3000

# URL publica del sitio, usada para enlaces de recuperacion de contrasena.
SITE_URL=https://markpublicidad.com

# Base de datos PostgreSQL. En Railway se configura automaticamente al agregar PostgreSQL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Para PostgreSQL local/NAS sin SSL usa false. En Railway normalmente omite esta variable o usa true.
DATABASE_SSL=false

# Usa un secreto largo y aleatorio.
JWT_SECRET=change-me-use-a-long-random-secret

# Credenciales iniciales / fallback del admin.
ADMIN_EMAIL=marka.publicidadimpresa@gmail.com
ADMIN_PASSWORD=change-me-before-production

# Email saliente para formulario de contacto y recuperacion de contrasena.
# Opcion recomendada: usa un SMTP dedicado o un proveedor transaccional.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# Alternativa si prefieres seguir con Gmail.
GMAIL_USER=marka.publicidadimpresa@gmail.com
GMAIL_PASS=google-app-password-without-spaces
CONTACT_EMAIL=marka.publicidadimpresa@gmail.com

# Uploads persistentes.
# Para el NAS Asustor en produccion usa UPLOAD_STORAGE=local y una ruta absoluta escribible.
UPLOAD_STORAGE=local
UPLOADS_DIR=/volume1/web/marka/uploads
PUBLIC_UPLOADS_URL=/uploads

# Alternativa futura: Cloudinary.
# Solo requerido si UPLOAD_STORAGE=cloudinary.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=marka-publicidad
