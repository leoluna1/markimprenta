# Credenciales — NUNCA subir
.env

# Datos sensibles — NUNCA subir a git
data/auth.json
data/admin-users.json
data/audit-events.json
data/contacts.json
data/reviews.json

# Dependencias
node_modules/

# Logs (el directorio se crea automáticamente al iniciar el servidor)
logs/*.log
logs/*.gz
qa-artifacts/

# Imágenes subidas por el admin (Railway usa almacenamiento efímero)
# Las imágenes se guardan en Cloudinary en producción
uploads/*
!uploads/.gitkeep

# Datos editables desde el admin (precios, productos, settings)
# Estos se editan directo en el NAS — git pull NO debe sobreescribirlos
data/pricing.json
data/settings.json
quote-prices.json

# Sistema operativo
.DS_Store
Thumbs.db

# Editor
.vscode/
